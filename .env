# W.I.T. Database Configuration

# Use SQLite for local development (no Docker needed)
WIT_DB_STORAGE_MODE=local
WIT_DB_SQLITE_PATH=data/wit_local.db

# PostgreSQL settings (for future use)
WIT_DB_POSTGRES_HOST=localhost
WIT_DB_POSTGRES_PORT=5432
WIT_DB_POSTGRES_DB=wit_db
WIT_DB_POSTGRES_USER=postgres
WIT_DB_POSTGRES_PASSWORD=postgres

# MQTT Configuration
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=wit-backend
